
type (_, _) same_length_lists =
  | Nil : ('a list, 'b list) same_length_lists
  | Cons : 'a * 'b * ('a list, 'b list) same_length_lists -> ('a list, 'b list) same_length_lists

let f g lists =
  let rec f' g lists acc =
    match lists with
    | Nil -> acc
    | Cons (x, y, rest) -> f' g rest ((g x y) :: acc)
  in List.rev (f' g lists [])

(* Usage *)
let result = f (fun x y -> x + y) (Cons (1, 10, Cons (2, 20, Cons (3, 30, Nil))))

(*
  can we enforce that len l1 = len l2 at type level ?
  prevent compiler warning - "pattern-matching is not exhaustive"
 *)
let f g l1 l2 =
  let rec f' g l1 l2 acc =
    match (l1, l2) with
    | [], [] -> acc
    | x :: xs, y :: ys -> f' g xs ys ( (g x y) :: acc )
  in reverse @@ f' g l1 l2 []

(* without having to do this *)
let f2 g l1 l2 =
  let rec f' g l1 l2 acc =
    match (l1, l2) with
    | [], [] | _, [] | [], _ -> acc
    | x :: xs, y :: ys -> f' g xs ys ( (g x y) :: acc )
  in reverse @@ f' g l1 l2 []
